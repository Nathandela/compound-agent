{
  "name": "learning-agent",
  "version": "0.2.5",
  "description": "Repository-scoped learning system for Claude Code",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "learning-agent": "./dist/cli.js",
    "lna": "./dist/cli.js",
    "learning-agent-mcp": "./dist/mcp.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nathandela/learning_agent.git"
  },
  "bugs": {
    "url": "https://github.com/Nathandela/learning_agent/issues"
  },
  "homepage": "https://github.com/Nathandela/learning_agent#readme",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:fast": "vitest run --exclude 'src/cli/**'",
    "test:watch": "vitest",
    "test:changed": "vitest run --changed HEAD~1",
    "test:all": "pnpm download-model && vitest run",
    "lint": "tsc --noEmit",
    "download-model": "node ./dist/cli.js download-model",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "claude",
    "learning",
    "memory",
    "ai"
  ],
  "author": "Nathan Delacrétaz",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@fast-check/vitest": "0.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "2.1.9",
    "fast-check": "4.5.3",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.25.3",
    "better-sqlite3": "^11.0.0",
    "chalk": "5.6.2",
    "commander": "^12.0.0",
    "node-llama-cpp": "^3.0.0",
    "zod": "^3.22.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "node-llama-cpp",
      "esbuild"
    ]
  }
}
